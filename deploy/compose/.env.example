# Image tag to deploy for frontend and backend.
JUSTAPPS_IMAGE_TAG=latest

# Host ports.
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=3000
BACKEND_BIND=127.0.0.1
BACKEND_PORT=8080

# Optional public edge proxy.
PUBLIC_HOST=apps.justlab.app
EDGE_HTTP_BIND=0.0.0.0
EDGE_HTTP_PORT=80

# PostgreSQL bootstrap credentials.
POSTGRES_DB=justapps
POSTGRES_USER=justapps
POSTGRES_PASSWORD=change-me

# Secrets.
BACKEND_JWT_SECRET=replace-with-secure-random-string
AUTH_SECRET=replace-with-secure-random-string

# Frontend URLs.
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
INTERNAL_API_URL=http://backend:8080/api/v1

# For the `edge` profile behind Coolify or another TLS terminator, switch these to your public HTTPS hostname.
# AUTH_URL=https://apps.justlab.app
# NEXT_PUBLIC_API_URL=/api/v1

# Optional Keycloak / OIDC. Leave disabled for the simplest local install.
BACKEND_OIDC_ENABLED=false
BACKEND_OIDC_ISSUER=
BACKEND_OIDC_CLIENT_ID=justapps
BACKEND_OIDC_ADMIN_GROUP=admin
BACKEND_OIDC_INSECURE=false
BACKEND_OIDC_DISABLE_LOCAL_AUTH=false
BACKEND_OIDC_DISABLE_REGISTRATION=false

AUTH_ADMIN_GROUP=admin
AUTH_OIDC_ID=
AUTH_OIDC_SECRET=
AUTH_OIDC_ISSUER=