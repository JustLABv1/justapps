# PLAIN App-Store Environment Configuration Template
# Copy this file to services/backend/.env and services/frontend/.env and adjust values.

# ==============================================================================
# BACKEND CONFIGURATION (services/backend/.env)
# ==============================================================================
BACKEND_LOG_LEVEL=info
BACKEND_PORT=8082

# Database
BACKEND_DATABASE_SERVER=localhost
BACKEND_DATABASE_PORT=5432
BACKEND_DATABASE_NAME=app_store
BACKEND_DATABASE_USER=postgres
BACKEND_DATABASE_PASSWORD=alertflow

# Security
BACKEND_JWT_SECRET=replace-with-secure-random-string

# OIDC / Keycloak
BACKEND_OIDC_ENABLED=true
BACKEND_OIDC_ISSUER=https://login-keycloak.apps.ocp4.your-cluster.com/realms/your-realm
BACKEND_OIDC_CLIENT_ID=app-store
BACKEND_OIDC_ADMIN_GROUP=admin
BACKEND_OIDC_INSECURE=false
BACKEND_OIDC_INSECURE=false


# ==============================================================================
# FRONTEND CONFIGURATION (services/frontend/.env)
# ==============================================================================
# API Connection
NEXT_PUBLIC_API_URL=http://localhost:8082/api/v1

# NextAuth core configuration
AUTH_SECRET=replace-with-secure-random-string
AUTH_URL=http://localhost:3000

# OIDC / Keycloak (NextAuth v5 providers)
AUTH_KEYCLOAK_ID=app-store
AUTH_KEYCLOAK_SECRET=your-client-secret
AUTH_KEYCLOAK_ISSUER=https://login-keycloak.apps.ocp4.your-cluster.com/realms/your-realm
AUTH_ADMIN_GROUP=admin
